12:36:51 AM [express] POST /api/projects/ea5a9192-67e9-42aa-9fb6-4a457308a029/test-items/import 201 in 94ms :: {"count":19,"items":[{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Angle - Torque Characteristics","plannedStartDate":"1/17/26","plannedEndDate":"1/23/26","actualEndDate":"1/23/26","testCondition":"1. Purpose\r\n  To check the SFA angle and torque characteristics\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power on\r\n  d) Connect input shaft to drive unit\r\n3. Test procedure\r\n  a) Position the SFA input shaft at the center\r\n  b) Rotate the SFA input shaft in the clockwise direction until the software end lock operates.\r\n  c) Repeat test for the opposite direction","judgmentCriteria":"1. Average torque : TBD\r\n2. Input torque difference : TBD\r\n3. software end lock angle : TBD\r\n4. No abnormality","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"472ea780-cb4f-4436-8805-1c54d57b8c73","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Actuator base performance - Torque controlled","plannedStartDate":"1/21/26","plannedEndDate":"1/28/26","actualEndDate":"1/28/26","testCondition":"1. Purpose\r\n  To check the SFA torque at different rotation speeds\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power on\r\n  d) Connect input shaft to drive unit\r\n3. Test procedure\r\n  a) Position SFA input shaft at mechanical end stop\r\n  b) Rotate SFA input shaft towards opposite lock at a rate specified below\r\n  c) Apply max feedback torque request the system is capable of\r\n  d) Repeat test for the opposite direction","judgmentCriteria":"1. 400deg/sec : Input torque ±10%\r\n2. 600deg/sec : Input torque ±10%\r\n3. 720deg/sec : Input torque ±10%\r\n4. 1200deg/sec : Input torque ±20%","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"29f8d59f-dad1-48c6-98db-69cf457ecee6","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Torque performance : Step mode","plannedStartDate":"1/26/26","plannedEndDate":"2/2/26","actualEndDate":"2/2/26","testCondition":"1. Purpose:\r\n  To check the SFA step response for torque control\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power on\r\n  d) Connect input shaft to rigid fixture\r\n3. Test procedure\r\n  a) Apply feedback torque requests : 1.0, 3.0, 10.0Nm step\r\n  b) Repeat test for the opposite direction","judgmentCriteria":"1. T_10 : MAX 50ms\r\n2. T_90 : MAX 100ms\r\n3. Overshoot : Reference\r\n4. Static deviation : ±20%\r\n5. Settling time : MAX 300ms+J1","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"43598b84-841b-4e0f-9fac-c231e32305a2","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Torque performance : Sweep mode","plannedStartDate":"1/31/26","plannedEndDate":"2/6/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA frequency response for torque control\r\n2.  Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power on\r\n  d) Connect input shaft to rigid fixture\r\n3. Test procedure\r\n  a) Apply feedback torque request \r\n   - Frequency : 0.5~25Hz (Log)\r\n   - Torque : 10~0.2Nm (Log)","judgmentCriteria":"1. MAX amplitude (0.5~5Hz) : 20%\r\n2. MAX amplitude (5Hz~) : Reference\r\n3. Phase shift (5Hz~) : Reference","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"e9fb3615-181a-4cd1-86ea-e7b046692c54","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Torque Ripple","plannedStartDate":"2/4/26","plannedEndDate":"2/11/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA torque ripple\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power on, Vehicle speed 0kph\r\n  d) Connect input shaft to drive unit\r\n3. Test procedure\r\n  a) Position SFA input shaft at -360˚ position\r\n  b) Rotate SFA input shaft : sinusoidal wave, ±360˚, 0.05Hz\r\n  c) Apply feedback torque request in resisting direction to input : square wave, ±3.5Nm, 0.5Hz","judgmentCriteria":"1. Max PTP variation: 0.7Nm (Target torque ±20%)\r\n2. Peak torque values from FFT:\r\n - Max 0.1Nm for 1 – 5Hz\r\n - Max 0.05Nm for f > 5Hz","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"057b07e2-ab80-4d02-8e62-7a0266591133","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Vertical / Axial stiffness","plannedStartDate":"1/15/26","plannedEndDate":"1/26/26","actualEndDate":"","testCondition":"1. Purpose:\r\n  To check the SFA vertical stiffness\r\n\r\n2. Test Set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power off\r\n\r\n3. Test procedure\r\n  a) Lock the lever\r\n  b) Measure the force and displacement while applying vertical force @ shaft end\r\n  c) Measure the force and displacement while applying axial force @ shaft end\r\n  d) Load applied ±300N","judgmentCriteria":"MAX 1.0mm (@300N)","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"d0345db0-d73d-43e2-8897-3f9da41ac817","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Lever Operating Force","plannedStartDate":"1/26/26","plannedEndDate":"2/2/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check SFA lever operating force\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Fix the height and length adjustment positions to   their middle point\r\n  c) Power off\r\n3 Test procedure\r\n  a) Release the lever\r\n  b) Lock the lever","judgmentCriteria":"1, Lock Force : 49~88.2N\r\n 2. Release Force : ReferenceE : TBD","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"06e044c4-7dd6-48f2-b197-15fcd41b7d18","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Tilting force / Teles force","plannedStartDate":"2/2/26","plannedEndDate":"2/9/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check SFA adjust operating force\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid   positions\r\n  c) Set the lever force to 63.7N\r\n  d) Power off\r\n3. Test procedure\r\n  a) Release lever\r\n  b) Measure the force and displacement while adjusting the tilt position\r\n  c) Measure the force and displacement while adjusting the teles position","judgmentCriteria":"1. Max Tilt Force: 150N\r\n 2. Max Teles Force: 98.1N\r\n 3. Displacement: Follow the drawing\r\n 4. No Abnormality","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"1ce763d9-5d41-4099-9656-60fdb97cb5d9","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Eletrical Resistance (Conductivity)","plannedStartDate":"1/26/26","plannedEndDate":"1/28/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA electrical resistance\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power off\r\n\r\n3. Test procedure\r\n  a) Measure the steering column and the column top MTG BRKT SHAFT UPR end cross resistance\r\n  b) a) is measured in the circumferential direction and the direction of rotation","judgmentCriteria":"Before Durability : MAX 4Ω/After : MAX 20 Ω","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"f631df49-0b36-464a-9adc-4038960789b0","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Natural Frequency","plannedStartDate":"1/28/26","plannedEndDate":"2/4/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA natural frequency\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power off\r\n  d) Attach the dummy mass 3.5kg (or steering wheel + DAB to input shaft)\r\n\r\n3. Test procedure\r\n  a) F.F.T. analysis\r\n  b) Hammering direction : Vertical, Horizontal\r\n  c) Measuring position : Tilt neutral/Tele neutral & Tilt neutral/Tele out","judgmentCriteria":"48 Hz Min","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"24f67a6c-1c2f-417b-af78-e623cde8f885","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Tilt / Teles Durability","plannedStartDate":"2/4/26","plannedEndDate":"2/25/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA tilt & tele operating durability\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) The standard MASS 3.5Kg or the steering wheel and driver airbag module mounted column shaft\r\n  c) Power on\r\n\r\n3. Test procedure\r\n  a) Sequence :\r\n   - 1cycle : Teles out → Tilt down → Teles in → Tilt up\r\n  b) Repeat 4,000 cycles","judgmentCriteria":"1.  Lever Force : MAX 88.2N\r\n 2.  MAX Tilt Force : MAX 150N\r\n 3.  MAX Teles Force : Max 98.1N\r\n 4.  No Abnormality","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"f17fa570-87d8-46a0-9a67-92f9ee0a1494","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Axial, Lateral and Bending load durability","plannedStartDate":"2/25/26","plannedEndDate":"3/18/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA axial, lateral and bending load durability\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture in each direction\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power off\r\n\r\n3. Test procedure\r\n  a) Test speed : 1±0.5Hz\r\n  b) Test cycles : Vertical 40,000 cycles / Lateral and axial : 15,000 cycles\r\n  c) Applied to load : Vertical, lateral, axial direction\r\n  d) Load applied 445 N","judgmentCriteria":"1.2mm Max (@300N)","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"89ad6733-56b9-4a30-ae5a-23fbb6dddc01","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Vibration Durability","plannedStartDate":"2/27/26","plannedEndDate":"3/24/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA system vibration durability\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture in vehicle geometry\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power on\r\n  d) Attach steering wheel and DAB or dummy mass\r\n\r\n3. Test procedure\r\n  a) Apply angle position request 0˚\r\n  b) Sweep profile\r\n    - 5~15Hz : 18㎜ p-p displacement limited\r\n    - 15~25Hz : 3.0g\r\n    - 25~100Hz : 2.0g\r\n    - 100~200Hz : 0.5g\r\n  c) Time per sweep : 20minutes\r\n  d) Sweeps per axis : 54times (18hr/axis)\r\n  e) Axis : x, y, z","judgmentCriteria":"1. No abmormaility","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"e90cecc3-9318-4599-a5bc-a054148de3ac","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Impact test (Body block)","plannedStartDate":"2/6/26","plannedEndDate":"2/23/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA energy absorbing characteristic\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture in vehicle geometry\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power off\r\n  d) Attach steering wheel & DAB to input shaft\r\n\r\n3. Test procedure\r\n  a) ECE R12\r\n  b) Dummy speed : 14.75mph(±0.15)\r\n  c) Dummy weight : 33.97~36.23kg","judgmentCriteria":"3ms Load : Not exceed 1111daN(11110N)","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"a6ba6347-9f67-4fe7-bb9c-c1ba9c988ab2","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Quasi-static Energy Abroption","plannedStartDate":"1/12/26","plannedEndDate":"1/21/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA energy absorption load performance\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture in horizontal direction\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power off\r\n\r\n3. Test procedure\r\n  a) Test speed : 100 mm/min\r\n  b) Load apply until full collapsed","judgmentCriteria":"Satisfy the force vs. displacement graph in the \r\n customer drawing","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"c790b949-370e-4856-890c-e53928cb3bde","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Drop mass","plannedStartDate":"1/21/26","plannedEndDate":"2/6/26","actualEndDate":"","testCondition":"1. Intention of Test\r\n  To check compression performance under impact load.\r\n2. Test specification\r\n  a) The collapse stroke satisfy at least 80%\r\n  b) No component damage should occur\r\n3. Test method\r\n  a) Drop weight : 50kg\r\n  b) Height : 1500mm\r\n  c) Mounting Angle : 11deg","judgmentCriteria":"1. The collapse stroke satisfy at least 80%\r\n 2. No component damage should occur","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"4cc12964-7b41-4a23-a8e8-4833528853e4","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Lever Strength","plannedStartDate":"2/23/26","plannedEndDate":"3/3/26","actualEndDate":"","testCondition":"1. Purpose:\r\n  To check lever strength\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture in horizontal direction\r\n  b) Lever lock condition\r\n3. Test procedure\r\n  a) Load applied : 300 N (to locking direction)\r\n  b) Load applied point : 13mm from end of lever","judgmentCriteria":"200N Min","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"8298a22a-40f5-4e63-98cf-d4002287c165","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Holding force test","plannedStartDate":"2/25/26","plannedEndDate":"3/5/26","actualEndDate":"","testCondition":"1. Purpose:\r\n  To check tilt & telescope holding force\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture in horizontal direction\r\n  b) Lever lock condition\r\n  c) Perform 3 times the following (unlock lever, do full \r\n     tilt and tele adjustment, bring to tilt & tele mid, lock \r\n     lever, wait for 1 minute)\r\n  d) Position : Tilt - Mid / Telescopic - Mid\r\n3. Test procedure\r\n  a) Load applied : 1,000 N (to Tilt Down & Telescope In direction)\r\n  b) Load applied point : Shaft end point","judgmentCriteria":"1. Tilt : MIN 784N (@Lever force 68.1N)\r\n 2. Teles : MIN 784N (@Lever force 68.1N)","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"40bc8010-0fc9-4379-850f-9796030b818e","lastModifiedDate":"2026-02-10"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Salt Spray Test","plannedStartDate":"3/5/26","plannedEndDate":"3/17/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check SFA the corrosion resistance of metallic materials and their coatings under a controlled,\r\n accelerated corrosive environment\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture for installation at the actual angle in the environmental chamber\r\n  b) Cover the SFA with vinyl to prevent direct saltwater penetration.\r\n  c) Power off\r\n\r\n3. Test procedure\r\n  a) Temperature : 35±2 ℃\r\n  b) PH range : 6.5~7.2\r\n  c) Concentration : 5% Nacl (sodium chloride)\r\n  d) 96 hours","judgmentCriteria":"1. No significant rust on any component\r\n 2. Device should operate as normal after the test","testData":"","testResult":"","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"d6ecaab2-9af9-4837-b62d-d114f82372d2","lastModifiedDate":"2026-02-10"}]}
