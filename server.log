,"attachments":[],"id":"3d73e5ea-7aad-4393-80f7-d82336a32f98","lastModifiedDate":"2026-02-09"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Vertical / Axial stiffness","plannedStartDate":"1/15/26","plannedEndDate":"1/26/26","actualEndDate":"","testCondition":"1. Purpose:\r\n  To check the SFA vertical stiffness\r\n\r\n2. Test Set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Adjust the height and length adjustment to their mid positions\r\n  c) Power off\r\n\r\n3. Test procedure\r\n  a) Lock the lever\r\n  b) Measure the force and displacement while applying vertical force @ shaft end\r\n  c) Measure the force and displacement while applying axial force @ shaft end\r\n  d) Load applied ±300N","judgmentCriteria":"MAX 1.0mm (@300N)","testData":"","testResult":"TBD","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"05faad5f-4f42-427c-aa8e-8a0042369061","lastModifiedDate":"2026-02-09"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Lever Operating Force","plannedStartDate":"1/26/26","plannedEndDate":"2/2/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check SFA lever operating force\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\n  b) Fix the height and length adjustment positions to   their middle point\r\n  c) Power off\r\n3 Test procedure\r\n  a) Release the lever\r\n  b) Lock the lever","judgmentCriteria":"1, Lock Force : 49~88.2N\r\n 2. Release Force : ReferenceE : TBD","testData":"","testResult":"TBD","progressStatus":"대기중","reportStatus":"대기중","notes":"","photos":[],"graphs":[],"attachments":[],"id":"784a95e8-4c36-4446-8339-b6b1b34fecfb","lastModifiedDate":"2026-02-09"},{"projectId":"ea5a9192-67e9-42aa-9fb6-4a457308a029","name":"Natural Frequency","plannedStartDate":"1/28/26","plannedEndDate":"2/4/26","actualEndDate":"","testCondition":"1. Purpose\r\n  To check the SFA natural frequency\r\n\r\n2. Test set-up\r\n  a) Secure the SFA to a rigid fixture\r\